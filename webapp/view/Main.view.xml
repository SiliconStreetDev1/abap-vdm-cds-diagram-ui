<mvc:View controllerName="nz.co.siliconstreet.vdmdiagrammer.controller.Main"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns="sap.m">
    
    <Page id="mainPage" showHeader="false" enableScrolling="false" class="sapUiNoContentPadding">
        <content>
            
            <f:FlexibleColumnLayout  id="fcl" layout="{ui>/fclLayout}">
                
                <f:beginColumnPages>
                    <mvc:XMLView id="viewSelection" viewName="nz.co.siliconstreet.vdmdiagrammer.view.Selection" />
                </f:beginColumnPages>

                <f:midColumnPages>
                    <mvc:XMLView id="viewDiagram" viewName="nz.co.siliconstreet.vdmdiagrammer.view.Diagram" />
                </f:midColumnPages>

            </f:FlexibleColumnLayout>
            
        </content>
    </Page>
</mvc:View>