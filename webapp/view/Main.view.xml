<mvc:View controllerName="nz.co.siliconstreet.vdmdiagrammer.controller.Main"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout"
    xmlns:customData="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
    
    <Page title="{i18n>appTitle}" showHeader="true" enableScrolling="false">
        
        <headerContent>
            <Button icon="sap-icon://full-screen" press="onToggleFullScreen" tooltip="{i18n>ttFullScreen}" />
        </headerContent>
        
        <content>
            <layout:Splitter id="mainSplitter" height="100%" width="100%">
                
                <ScrollContainer vertical="true" horizontal="false" height="100%">
                    <layoutData>
                        <layout:SplitterLayoutData size="400px" id="leftPaneLayout" />
                    </layoutData>

                    <VBox class="sapUiSmallMargin">
                        
                        <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiSmallMarginBottom">
                            <Label text="{i18n>lblShowHelp}" design="Bold" />
                            <Switch state="{ui>/showHelp}" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                        </HBox>
                        
                        <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                            <Label text="{i18n>lblCdsName}" design="Bold" />
                            <core:Icon src="sap-icon://information" color="#0070f2" visible="{ui>/showHelp}" 
                                       press="onShowInfo" customData:infoType="CdsName" tooltip="{i18n>ttClickInfo}" />
                        </HBox>
                        
                        <Input id="cmbCdsName" 
                               width="100%" 
                               showValueHelp="true"
                               valueHelpRequest="onCdsValueHelpRequest"
                               showSuggestion="true"
                               suggestionItems="{history>/items}">
                            <suggestionItems>
                                <core:Item key="{history>name}" text="{history>name}" />
                            </suggestionItems>
                        </Input>

                        <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiSmallMarginTop">
                            <Label text="{i18n>lblEngine}" design="Bold" />
                            <core:Icon src="sap-icon://information" color="#0070f2" visible="{ui>/showHelp}" 
                                       press="onShowInfo" customData:infoType="Engine" tooltip="{i18n>ttClickInfo}" />
                        </HBox>
                        <Select id="selEngine" width="100%" selectedKey="{ui>/activeEngine}" change="onEngineChange">
                            <core:Item key="PLANTUML" text="{i18n>optPlantUml}" />
                            <core:Item key="MERMAID" text="{i18n>optMermaid}" />
                            <core:Item key="GRAPHVIZ" text="{i18n>optGraphviz}" />
                            <core:Item key="D2" text="{i18n>optD2}" />
                        </Select>

                        <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiSmallMarginTop">
                            <Label text="{i18n>lblLevels}" design="Bold" />
                            <core:Icon src="sap-icon://information" color="#0070f2" visible="{ui>/showHelp}"
                                       press="onShowInfo" customData:infoType="Levels" tooltip="{i18n>ttClickInfo}" />
                        </HBox>
                        <StepInput id="stepMaxLevel" value="1" min="1" max="10" width="100%" />

                        <Label text="{i18n>lblVariants}" class="sapUiSmallMarginTop" design="Bold" />
                        <HBox width="100%" alignItems="Center" justifyContent="End">
                            <Select id="selVariant" items="{variants>/items}" change="onVariantChange" forceSelection="false" 
                                    visible="{= ${variants>/items}.length > 0 }" class="sapUiTinyMarginRight">
                                <layoutData>
                                    <FlexItemData growFactor="1" /> </layoutData>
                                <core:Item key="{variants>name}" text="{variants>name}" />
                            </Select>
                            
                            <Button icon="sap-icon://save" tooltip="{i18n>ttSaveVariant}" press="onSaveVariant" type="Transparent" />
                            <Button icon="sap-icon://delete" tooltip="{i18n>ttDeleteVariant}" press="onDeleteVariant" type="Transparent" 
                                    visible="{= ${variants>/items}.length > 0 }" />
                        </HBox>

      <Button id="btnGenerate" text="{i18n>btnGenerate}" press="onGenerate" type="Emphasized" width="100%" class="sapUiLargeMarginTop sapUiMediumMarginBottom" />

                        <Panel headerText="Formatting Options" expandable="true" expanded="true" width="100%" class="sapUiMeidumMarginTop sapUiMediumMarginBottom">
                            <VBox visible="{= ${ui>/activeEngine} === 'PLANTUML' }" width="100%">
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiTinyMarginBottom">
                                    <Label text="Line Routing" design="Bold"/>
                                    <Select selectedKey="{ui>/formatPlantUML/lineStyle}">
                                        <core:Item key="default" text="Smooth Curves (Default)" />
                                        <core:Item key="ortho" text="Orthogonal (90° Angles)" />
                                        <core:Item key="polyline" text="Polyline (Straight Angles)" />
                                    </Select>
                                </HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center"><Label text="Spaced Out" /><Switch state="{ui>/formatPlantUML/spaced_out}" customTextOn="Yes" customTextOff="No"/></HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center"><Label text="Staggered" /><Switch state="{ui>/formatPlantUML/staggered}" customTextOn="Yes" customTextOff="No"/></HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center"><Label text="Modern Style" /><Switch state="{ui>/formatPlantUML/modern}" customTextOn="Yes" customTextOff="No"/></HBox>
                            </VBox>

                            <VBox visible="{= ${ui>/activeEngine} === 'GRAPHVIZ' }" width="100%">
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiTinyMarginBottom">
                                    <Label text="Line Routing" design="Bold"/>
                                    <Select selectedKey="{ui>/formatGraphviz/lineStyle}">
                                        <core:Item key="default" text="Smooth Curves (Default)" />
                                        <core:Item key="ortho" text="Orthogonal (90° Angles)" />
                                        <core:Item key="polyline" text="Polyline (Straight Angles)" />
                                    </Select>
                                </HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center"><Label text="Spaced Out" /><Switch state="{ui>/formatGraphviz/spaced_out}" customTextOn="Yes" customTextOff="No"/></HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center"><Label text="Modern Style" /><Switch state="{ui>/formatGraphviz/modern}" customTextOn="Yes" customTextOff="No"/></HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center"><Label text="Left to Right Flow" /><Switch state="{ui>/formatGraphviz/left_to_right}" customTextOn="Yes" customTextOff="No"/></HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center"><Label text="Concentrate Edges" /><Switch state="{ui>/formatGraphviz/concentrate_edges}" customTextOn="Yes" customTextOff="No"/></HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center"><Label text="Monochrome" /><Switch state="{ui>/formatGraphviz/monochrome}" customTextOn="Yes" customTextOff="No"/></HBox>
                            </VBox>

                            <VBox visible="{= ${ui>/activeEngine} === 'MERMAID' }" width="100%">
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiTinyMarginBottom">
                                    <Label text="Direction" design="Bold"/>
                                    <Select selectedKey="{ui>/formatMermaid/direction}">
                                        <core:Item key="TB" text="Top to Bottom" />
                                        <core:Item key="LR" text="Left to Right" />
                                    </Select>
                                </HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                    <Label text="Theme" design="Bold"/>
                                    <Select selectedKey="{ui>/formatMermaid/theme}">
                                        <core:Item key="default" text="Default" />
                                        <core:Item key="dark" text="Dark" />
                                        <core:Item key="forest" text="Forest" />
                                        <core:Item key="neutral" text="Neutral" />
                                    </Select>
                                </HBox>
                            </VBox>

                            <VBox visible="{= ${ui>/activeEngine} === 'D2' }" width="100%">
                                <Text text="Default formatting applied for D2." />
                            </VBox>
                        </Panel>

                  
                        <Panel headerText="{i18n>hdrAdvanced}" expandable="true" expanded="false" width="100%">
                            
                            <Label text="{i18n>lblEntityDetails}" design="Bold" />
                            
                            <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                <Label text="{i18n>lblShowKeys}" />
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://information" class="sapUiMediumMarginEnd" color="#0070f2" visible="{ui>/showHelp}"
                                               press="onShowInfo" customData:infoType="ShowKeys" tooltip="{i18n>ttClickInfo}" />
                                    <Switch id="swKeys" state="true" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                            </HBox>

                            <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                <Label text="{i18n>lblShowFields}" />
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://information" class="sapUiMediumMarginEnd" color="#0070f2" visible="{ui>/showHelp}"
                                               press="onShowInfo" customData:infoType="ShowFields" tooltip="{i18n>ttClickInfo}" />
                                    <Switch id="swFields" state="true" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                            </HBox>

                            <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                <Label text="{i18n>lblShowAssocFields}" />
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://information" class="sapUiMediumMarginEnd" color="#0070f2" visible="{ui>/showHelp}"
                                               press="onShowInfo" customData:infoType="ShowAssocFields" tooltip="{i18n>ttClickInfo}" />
                                    <Switch id="swAssocFields" state="true" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                            </HBox>

                            <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                <Label text="{i18n>lblShowBase}" />
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://information" class="sapUiMediumMarginEnd" color="#0070f2" visible="{ui>/showHelp}"
                                               press="onShowInfo" customData:infoType="ShowBase" tooltip="{i18n>ttClickInfo}" />
                                    <Switch id="swBase" state="true" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                            </HBox>

                            <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                <Label text="{i18n>lblCustomOnly}" />
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://information" class="sapUiMediumMarginEnd" color="#0070f2" visible="{ui>/showHelp}"
                                               press="onShowInfo" customData:infoType="CustomOnly" tooltip="{i18n>ttClickInfo}" />
                                    <Switch id="swCustomOnly" state="false" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                            </HBox>

                            <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiSmallMarginTop sapUiTinyMarginBottom">
                                <Label text="{i18n>lblRelMode}" design="Bold" />
                                <core:Icon src="sap-icon://information" color="#0070f2" visible="{ui>/showHelp}"
                                           press="onShowInfo" customData:infoType="RelMode" tooltip="{i18n>ttClickInfo}" />
                            </HBox>
                            
                            <SegmentedButton id="segRelMode" selectedKey="LINES" selectionChange="onRelModeChange" width="100%" class="sapUiTinyMarginBottom">
                                <items>
                                    <SegmentedButtonItem key="LINES" text="{i18n>optLines}" />
                                    <SegmentedButtonItem key="DISCOVERY" text="{i18n>optDiscovery}" />
                                </items>
                            </SegmentedButton>

                            <VBox id="boxLines" visible="true" width="100%">
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                    <Label text="{i18n>lblLineAssoc}" />
                                    <Switch id="swLineAssoc" state="true" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                    <Label text="{i18n>lblLineComp}" />
                                    <Switch id="swLineComp" state="true" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                    <Label text="{i18n>lblLineInherit}" />
                                    <Switch id="swLineInherit" state="true" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                            </VBox>

                            <VBox id="boxDiscovery" visible="false" width="100%">
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                    <Label text="{i18n>lblDiscAssoc}" />
                                    <Switch id="swDiscAssoc" state="true" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                    <Label text="{i18n>lblDiscComp}" />
                                    <Switch id="swDiscComp" state="true" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
                                    <Label text="{i18n>lblDiscInherit}" />
                                    <Switch id="swDiscInherit" state="true" customTextOn="{i18n>lblYes}" customTextOff="{i18n>lblNo}" />
                                </HBox>
                            </VBox>

                            <VBox class="sapUiMediumMarginTop" width="100%">
                                <Label text="{i18n>lblFilters}" design="Bold" />
                                
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiTinyMarginTop">
                                    <Label text="{i18n>lblInclude}" />
                                    <core:Icon src="sap-icon://information" color="#0070f2" visible="{ui>/showHelp}"
                                               press="onShowInfo" customData:infoType="Include" tooltip="{i18n>ttClickInfo}" />
                                </HBox>
                                <MultiInput id="inpInclude" 
                                            placeholder="{i18n>phInclude}" 
                                            width="100%" 
                                            showValueHelp="true"
                                            valueHelpRequest="onCdsValueHelpRequest" />
                                
                                <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiTinyMarginTop">
                                    <Label text="{i18n>lblExclude}" />
                                    <core:Icon src="sap-icon://information" color="#0070f2" visible="{ui>/showHelp}"
                                               press="onShowInfo" customData:infoType="Exclude" tooltip="{i18n>ttClickInfo}" />
                                </HBox>
                                <MultiInput id="inpExclude" 
                                            placeholder="{i18n>phExclude}" 
                                            width="100%" 
                                            showValueHelp="true"
                                            valueHelpRequest="onCdsValueHelpRequest" />
                            </VBox>

                        </Panel>
                    </VBox>
                </ScrollContainer>

                <VBox height="100%" width="100%">
                    <layoutData>
                        <layout:SplitterLayoutData size="auto" />
                    </layoutData>
                    
                    <Toolbar id="toolbarActions" visible="false">
                        <ToolbarSpacer />
                        <Button id="btnCopy" icon="sap-icon://copy" text="{i18n>btnCopy}" press="onCopySyntax" />
                        <Button id="btnDownloadSrc" icon="sap-icon://download" text="{i18n>btnDownloadSrc}" press="onDownloadSource" />
                        <Button id="btnDownloadImg" icon="sap-icon://camera" text="{i18n>btnDownloadImg}" press="onDownloadImage" type="Emphasized" />
                        <Button id="btnDownloadPng" icon="sap-icon://camera" text="{i18n>btnDownloadPng}" press="onDownloadPng" type="Attention" />
                    </Toolbar>
                    
                    <VBox height="100%" width="100%" justifyContent="Center" alignItems="Center" renderType="Bare">
                        <IllustratedMessage id="msgEmpty" visible="true" illustrationType="sapIllus-SearchEarth" title="{i18n>msgEmptyTitle}" description="{i18n>msgEmptyDesc}" />
                        
                        <MessageStrip id="msgError" visible="false" type="Error" showIcon="true" class="sapUiMargin" />
                        <core:HTML id="htmlRenderer" visible="false" />
                    </VBox>
                </VBox>

            </layout:Splitter>
        </content>
    </Page>
</mvc:View>