<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <VBox visible="{= ${ui>/activeEngine} === 'CYTOSCAPE' }" width="100%">
        <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiTinyMarginBottom">
            <Label text="Layout Algorithm" design="Bold"/>
            <Select selectedKey="{ui>/formatCytoscape/layout_algorithm}">
                <core:Item key="cose" text="Physics (Auto-Untangle)" />
                <core:Item key="grid" text="Grid (Structured)" />
                <core:Item key="circle" text="Circular" />
            </Select>
        </HBox>
        <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiTinyMarginBottom">
            <Label text="SAP Theme" design="Bold"/>
            <Select selectedKey="{ui>/formatCytoscape/theme}">
                <core:Item key="fiori_light" text="Morning Horizon (Light)" />
                <core:Item key="fiori_dark" text="Evening Horizon (Dark)" />
            </Select>
        </HBox>
        <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiTinyMarginBottom">
            <Label text="Line Routing" design="Bold"/>
            <Select selectedKey="{ui>/formatCytoscape/line_style}">
                <core:Item key="bezier" text="Smooth Curves (Default)" />
                <core:Item key="taxi" text="Orthogonal (90° Angles)" />
            </Select>
        </HBox>
        <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center">
            <Label text="Animate Physics" />
            <Switch state="{ui>/formatCytoscape/animate}" customTextOn="Yes" customTextOff="No"/>
        </HBox>
        <HBox justifyContent="SpaceBetween" width="100%" alignItems="Center" class="sapUiTinyMarginTop">
            <Label text="Node Spacing (px)" />
            <StepInput value="{ui>/formatCytoscape/node_spacing}" min="50" max="400" step="25" width="120px" />
        </HBox>
    </VBox>
</core:FragmentDefinition>